# ─────────────────────────────────────────────
# Auto-Shorts Pipeline — Environment Variables
# Copy this file to .env and fill in the values
# ─────────────────────────────────────────────

# ── Database (MongoDB) ────────────────────────
# MongoDB Atlas (production) or local (development)
MONGODB_URI="mongodb+srv://<user>:<password>@cluster0.mongodb.net/short_app?retryWrites=true&w=majority"

# Local development alternative:
# MONGODB_URI="mongodb://localhost:27017/short_app"

# ── Redis (BullMQ queue) ──────────────────────
REDIS_URL="redis://localhost:6379"

# ── Reddit API ────────────────────────────────
# Create an app at https://www.reddit.com/prefs/apps
# Type: script
REDDIT_CLIENT_ID="your_reddit_client_id"
REDDIT_CLIENT_SECRET="your_reddit_client_secret"
REDDIT_USERNAME="your_reddit_username"
REDDIT_PASSWORD="your_reddit_password"

# ── YouTube Data API v3 ───────────────────────
# Create credentials at https://console.cloud.google.com
# Enable YouTube Data API v3, create OAuth2 client
YOUTUBE_CLIENT_ID="your_youtube_client_id"
YOUTUBE_CLIENT_SECRET="your_youtube_client_secret"
YOUTUBE_REFRESH_TOKEN="your_youtube_refresh_token"

# ── Google Drive (clipshortnews@gmail.com) ────
# Same Google Cloud project or separate OAuth2 client
# Scopes needed: https://www.googleapis.com/auth/drive.file
GOOGLE_DRIVE_CLIENT_ID="your_drive_client_id"
GOOGLE_DRIVE_CLIENT_SECRET="your_drive_client_secret"
GOOGLE_DRIVE_REFRESH_TOKEN="your_drive_refresh_token"

# ── ElevenLabs TTS ───────────────────────────
# Required — used for text-to-speech audio generation
# Get your API key at https://elevenlabs.io
ELEVENLABS_API_KEY="your_elevenlabs_api_key"
# Optional — defaults to Rachel (21m00Tcm4TlvDq8ikWAM) if not set
# Browse voices at https://elevenlabs.io/voice-library
# ELEVENLABS_VOICE_ID="21m00Tcm4TlvDq8ikWAM"

# ── OpenAI (optional — for script generation) ─
# OPENAI_API_KEY="your_openai_api_key"

# ── TikTok Content Posting API ───────────────
# Create an app at https://developers.tiktok.com
# Enable "Content Posting API" and add scope: video.publish
# Run: npx tsx scripts/get-tiktok-token.ts to obtain the initial tokens
TIKTOK_CLIENT_KEY="your_tiktok_client_key"
TIKTOK_CLIENT_SECRET="your_tiktok_client_secret"
TIKTOK_ACCESS_TOKEN="your_tiktok_access_token"
TIKTOK_REFRESH_TOKEN="your_tiktok_refresh_token"
TIKTOK_OPEN_ID="your_tiktok_open_id"

# ── App ───────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
